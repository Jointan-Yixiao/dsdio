# ---- Python ----
.venv/
__pycache__/
*.pyc
.pytest_cache/

# ---- 密钥 / 个人设置（含明文 API key，绝不上传）----
.env
settings.json

# ---- 运行时产物 / 个人数据 ----
cache/
# WebView2 用户数据（含麦克风授权、浏览缓存）
.webview/
