long_memory.json
short_memory.json
# 日志（app_err.log / ncm_*.log 等）
*.log

# ---- 大文件：模型（数百 MB，GitHub 拒收 >100MB；按 README 自行获取/自动下载）----
models/

# ---- Node 依赖（用 npm install 还原，勿提交）----
node_modules/

# ---- 音源后端目录（用户自部署，含 NCM/UNM，绝不上仓）----
music-api/
unm-api/

# ---- 其它工具留存 ----
musicdl_outputs/
