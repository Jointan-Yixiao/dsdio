# 复制本文件为 .env 并填入你的 DeepSeek API Key
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# 可选：DeepSeek 模型名。留空用默认 deepseek-v4-flash。
# 如果你的账号没有这个模型（首跑报模型不存在），改成账号可用的，例如官方公开的 deepseek-chat。
# DEEPSEEK_MODEL=deepseek-chat

# 可选：天气。填了才会显示当地天气并让 Dsdio 据天气聊天 / 选歌。
# 申请地址：https://openweathermap.org/api （免费 key）
# OPENWEATHER_API_KEY=

# 可选：如果国外新闻源需要走代理，填入代理地址（HTTP 代理）
# 例如 Clash 默认：http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
